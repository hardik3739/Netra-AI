# ═══════════════════════════════════════════════════════
# NetraAI — Environment Variables
# SuRaksha Cyber Hackathon 2.0 | Canara Bank
# ═══════════════════════════════════════════════════════

# PostgreSQL Database Configuration
# Change PASSWORD to match your PostgreSQL installation
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:netraai123@localhost:5432/netraai_db

# SQLite Fallback (if PostgreSQL not available)
# Uncomment to use SQLite instead (useful for local testing)
# SQLITE_DATABASE_URL=sqlite:///./netraai_local.db

# JWT Secret (change in production to a secure random string)
SECRET_KEY=netraai_super_secret_jwt_key_2024_change_in_production

# Application Environment
APP_ENV=development

# Microsoft Phi-3 Mini LLM (via Ollama)
# LocalLLM for RegPilot MAP extraction
# Install Ollama from https://ollama.com
# Pull model: ollama pull phi3 (2.3GB)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# File Upload Settings
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# Server Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
DEBUG=true

# App settings
APP_ENV=development
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
